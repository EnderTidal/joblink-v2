# All optional — JobLink runs with none of these set.

# Port to listen on (default 3000)
#PORT=3000

# Path to the SQLite database file (default ./data/joblink.db)
#JOBLINK_DB=./data/joblink.db

# Enables Claude-powered document parsing + smarter Help answers.
# Without it, a deterministic parser and built-in FAQ take over.
#ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults: claude-haiku-4-5 for both)
#JOBLINK_PARSE_MODEL=claude-haiku-4-5
#JOBLINK_HELP_MODEL=claude-haiku-4-5

# Whippy credentials are NOT env vars — they live in Admin → Settings (the settings table).
